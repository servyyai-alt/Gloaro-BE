        { "name": "Get Settings", "request": { "method": "GET", "url": "{{baseUrl}}/admin/settings" } },
        { "name": "Upsert Setting", "request": { "method": "PUT", "url": "{{baseUrl}}/admin/settings/platform.name", "body": { "mode": "raw", "raw": "{\n  \"value\": \"Gloaro\",\n  \"group\": \"platform\",\n  \"isPublic\": true\n}", "options": { "raw": { "language": "json" } } } } }
