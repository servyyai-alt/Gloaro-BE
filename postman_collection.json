        { "name": "Revenue Report", "request": { "method": "GET", "url": "{{baseUrl}}/reports/revenue?from=2025-01-01" } },
        { "name": "Vendor Report", "request": { "method": "GET", "url": "{{baseUrl}}/reports/vendors" } },
        { "name": "Lead Report", "request": { "method": "GET", "url": "{{baseUrl}}/reports/leads" } }
      ]
    },
    {
      "name": "Referrals",
      "item": [
        { "name": "Get My Referrals", "request": { "method": "GET", "url": "{{baseUrl}}/referrals/my" } },
        { "name": "Get My Referral Code", "request": { "method": "GET", "url": "{{baseUrl}}/referrals/my/code" } },
        { "name": "Get Referral Stats", "request": { "method": "GET", "url": "{{baseUrl}}/referrals/my/stats" } }
      ]
