    {
      "name": "Admin",
      "item": [
        { "name": "Dashboard", "request": { "method": "GET", "url": "{{baseUrl}}/admin/dashboard" } },
        { "name": "Pending Approvals", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/admin/pending-approvals?type=vendor", "query": [{"key":"type","value":"vendor"}] } } },
        { "name": "Audit Logs", "request": { "method": "GET", "url": "{{baseUrl}}/admin/audit-logs?page=1&limit=20" } },
        { "name": "Create Admin", "request": { "method": "POST", "url": "{{baseUrl}}/admin/create-admin", "body": { "mode": "raw", "raw": "{\n  \"name\": \"New Admin\",\n  \"email\": \"newadmin@vendordirectory.com\",\n  \"password\": \"Admin@123\",\n  \"phone\": \"9000000000\"\n}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Get Banners", "request": { "method": "GET", "url": "{{baseUrl}}/admin/banners" } },
        { "name": "Create Banner", "request": { "method": "POST", "url": "{{baseUrl}}/admin/banners", "body": { "mode": "raw", "raw": "{\n  \"title\": \"Grow with Gloaro\",\n  \"subtitle\": \"Connect with verified businesses\",\n  \"placement\": \"home\",\n  \"order\": 1,\n  \"isActive\": true\n}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Get FAQs", "request": { "method": "GET", "url": "{{baseUrl}}/admin/faqs" } },
